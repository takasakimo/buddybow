generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                      Int                        @id @default(autoincrement())
  email                   String                     @unique
  password                String
  name                    String
  role                    String                     @default("user")
  assignedAdminId         Int?                       @map("assigned_admin_id")
  assignedAdmin           User?                      @relation("UserAssignedAdmin", fields: [assignedAdminId], references: [id], onDelete: SetNull)
  assignedUsers           User[]                     @relation("UserAssignedAdmin")
  createdAt               DateTime                   @default(now()) @map("created_at")
  updatedAt               DateTime                   @updatedAt @map("updated_at")
  
  // マイページ関連
  userProgress            UserProgress?
  diagnoses               Diagnosis[]
  diagnosisUrls           DiagnosisUrl[]
  roadmaps                Roadmap[]
  dailyReports            DailyReport[]
  consultations           Consultation[]
  achievements            Achievement[]
  motivationMessages      MotivationMessage[]
  studySessionParticipants StudySessionParticipant[]
  interviews              Interview[]

  /// 面談ヒアリング等（管理者・担当メンターのみ。受講生には非表示）
  adminHearingNotes   String? @db.Text @map("admin_hearing_notes")
  adminBackground     String? @db.Text @map("admin_background")
  adminMindset        String? @db.Text @map("admin_mindset")
  adminCurrentGoals   String? @db.Text @map("admin_current_goals")
  /// 診断結果の補足・メンター所見など（受講生には非表示）
  adminDiagnosisNotes String? @db.Text @map("admin_diagnosis_notes")

  @@map("users")
}

// お知らせ
model Announcement {
  id          String   @id @default(cuid())
  title       String
  content     String
  category    String   // news, event, update
  isPublished Boolean  @default(true) @map("is_published")
  publishedAt DateTime @default(now()) @map("published_at")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("announcements")
}

// 勉強会
model StudySession {
  id           String                     @id @default(cuid())
  title        String
  description  String?
  startTime    DateTime                   @map("start_time")
  endTime      DateTime                   @map("end_time")
  zoomId       String?                    @map("zoom_id")
  location     String?
  maxCapacity  Int?                       @map("max_capacity")
  status       String                     @default("upcoming")
  createdAt    DateTime                   @default(now()) @map("created_at")
  updatedAt    DateTime                   @updatedAt @map("updated_at")
  participants StudySessionParticipant[]

  @@map("study_sessions")
}

// 勉強会参加者
model StudySessionParticipant {
  id              String       @id @default(cuid())
  studySessionId  String       @map("study_session_id")
  studySession    StudySession @relation(fields: [studySessionId], references: [id], onDelete: Cascade)
  userId          Int          @map("user_id")
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  status          String       @default("pending")
  appliedAt       DateTime     @default(now()) @map("applied_at")
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  @@unique([studySessionId, userId])
  @@map("study_session_participants")
}

// プログレス管理
model UserProgress {
  id              String   @id @default(cuid())
  userId          Int      @unique @map("user_id")
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  currentPhase    String   @map("current_phase")
  overallProgress Int      @default(0) @map("overall_progress")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("user_progress")
}

// 診断URL
model DiagnosisUrl {
  id              String   @id @default(cuid())
  userId          Int      @map("user_id")
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  url             String
  status          String   @default("pending") // pending, processing, completed, failed
  diagnosisId     String?  @map("diagnosis_id")
  diagnosis       Diagnosis? @relation(fields: [diagnosisId], references: [id], onDelete: SetNull)
  errorMessage    String?  @map("error_message")
  lastCheckedAt   DateTime? @map("last_checked_at")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("diagnosis_urls")
}

// LP等からの匿名診断結果（会員登録前の顧客）
model DiagnosisSubmission {
  id              String           @id @default(cuid())
  nickname        String           @map("nickname")
  personalityType String?          @map("personality_type")
  resultData      Json?            @map("result_data")
  diagnosedAt     DateTime         @map("diagnosed_at")
  source          String?          @default("lp")
  lineUserId      String?          @map("line_user_id")
  lineReportSentAt DateTime?       @map("line_report_sent_at")
  createdAt       DateTime         @default(now()) @map("created_at")
  meetingBookings MeetingBooking[]

  @@map("diagnosis_submissions")
}

// LINEログインOAuth中の一時state管理
model LineOAuthState {
  id           String   @id @default(cuid())
  state        String   @unique
  diagnosisId  String   @map("diagnosis_id")
  expiresAt    DateTime @map("expires_at")
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("line_oauth_states")
}

// 診断結果
model Diagnosis {
  id              String   @id @default(cuid())
  userId          Int      @map("user_id")
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  personalityType String?  @map("personality_type")
  skillMap        Json?    @map("skill_map")
  strengths       Json?    @map("strengths")
  weaknesses      Json?    @map("weaknesses")
  recommendations Json?    @map("recommendations")
  pdfUrl          String?  @map("pdf_url")
  comment         String?  @map("comment")
  diagnosisUrls   DiagnosisUrl[]
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("diagnoses")
}

// ロードマップ
model Roadmap {
  id              String      @id @default(cuid())
  userId          Int         @map("user_id")
  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  title           String
  description     String?
  targetMonths    Int         @map("target_months")
  startDate       DateTime    @map("start_date")
  endDate         DateTime    @map("end_date")
  milestones      Milestone[]
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  @@map("roadmaps")
}

// マイルストーン（月別 ToDo、targetMonths に合わせて 1〜N ヶ月目）
model Milestone {
  id          String   @id @default(cuid())
  roadmapId   String   @map("roadmap_id")
  roadmap     Roadmap  @relation(fields: [roadmapId], references: [id], onDelete: Cascade)
  month       Int      @default(1) @map("month") // 1, 2, 3... ヶ月目
  title       String
  description String?
  targetDate  DateTime @map("target_date")
  completed   Boolean  @default(false)
  completedAt DateTime? @map("completed_at")
  order       Int
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  traineeEntry MilestoneTraineeEntry?
  subItems    MilestoneSubItem[]

  @@map("milestones")
}

// マイルストーンのサブ項目（ツリー型・多階層）
model MilestoneSubItem {
  id          String   @id @default(cuid())
  milestoneId String   @map("milestone_id")
  milestone   Milestone @relation(fields: [milestoneId], references: [id], onDelete: Cascade)
  parentId    String?  @map("parent_id") // null = トップレベル
  parent      MilestoneSubItem? @relation("SubItemTree", fields: [parentId], references: [id], onDelete: Cascade)
  children    MilestoneSubItem[] @relation("SubItemTree")
  title       String
  description String?  @map("description") @db.Text
  order       Int      @default(0)
  completed   Boolean  @default(false)
  completedAt DateTime? @map("completed_at")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  traineeEntry SubItemTraineeEntry?

  @@map("milestone_sub_items")
}

// サブ項目の受講生記入（進捗・メモ・思ったこと・質問 ＋ 管理者コメント）
model SubItemTraineeEntry {
  id                   String   @id @default(cuid())
  subItemId            String   @unique @map("sub_item_id")
  subItem              MilestoneSubItem @relation(fields: [subItemId], references: [id], onDelete: Cascade)
  progress             String?  @map("progress") @db.Text
  memo                 String?  @map("memo") @db.Text
  thought              String?  @map("thought") @db.Text
  question             String?  @map("question") @db.Text
  adminProgressReply   String?  @map("admin_progress_reply") @db.Text
  adminMemoReply       String?  @map("admin_memo_reply") @db.Text
  adminThoughtReply    String?  @map("admin_thought_reply") @db.Text
  adminQuestionReply   String?  @map("admin_question_reply") @db.Text
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  @@map("sub_item_trainee_entries")
}

// 受講生のマイルストーン記入（進捗・メモ・思ったこと・質問 ＋ 管理者コメント）
model MilestoneTraineeEntry {
  id                   String   @id @default(cuid())
  milestoneId          String   @unique @map("milestone_id")
  milestone            Milestone @relation(fields: [milestoneId], references: [id], onDelete: Cascade)
  progress             String?  @map("progress") @db.Text
  memo                 String?  @map("memo") @db.Text
  thought              String?  @map("thought") @db.Text
  question             String?  @map("question") @db.Text
  adminProgressReply   String?  @map("admin_progress_reply") @db.Text
  adminMemoReply       String?  @map("admin_memo_reply") @db.Text
  adminThoughtReply    String?  @map("admin_thought_reply") @db.Text
  adminQuestionReply   String?  @map("admin_question_reply") @db.Text
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  @@map("milestone_trainee_entries")
}

// ロードマップテンプレート（管理者が月別ゴールを登録・編集）
model RoadmapTemplate {
  id        String   @id @default(cuid())
  name      String   @map("name")
  items     RoadmapTemplateItem[]
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("roadmap_templates")
}

// テンプレートの月別アイテム（マイルストーンひな形）
model RoadmapTemplateItem {
  id          String           @id @default(cuid())
  templateId  String           @map("template_id")
  template    RoadmapTemplate  @relation(fields: [templateId], references: [id], onDelete: Cascade)
  month       Int              @map("month")
  title       String           @map("title")
  description String?          @map("description") @db.Text
  order       Int              @default(0)
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")

  @@map("roadmap_template_items")
}

// 日報・週報
model DailyReport {
  id          String   @id @default(cuid())
  userId      Int      @map("user_id")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date        DateTime
  type        String
  workHours   Float?   @map("work_hours")
  revenue     Float?
  content     String
  challenges  String?
  learnings   String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("daily_reports")
}

// 相談・コミュニケーション
model Consultation {
  id          String   @id @default(cuid())
  userId      Int      @map("user_id")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  content     String
  status      String   @default("pending")
  answer      String?
  answeredAt  DateTime? @map("answered_at")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("consultations")
}

// 達成・バッジ
model Achievement {
  id          String   @id @default(cuid())
  userId      Int      @map("user_id")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  description String?
  badgeType   String   @map("badge_type")
  earnedAt    DateTime @default(now()) @map("earned_at")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("achievements")
}

// 応援メッセージ
model MotivationMessage {
  id        String   @id @default(cuid())
  userId    Int      @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  message   String
  fromAdmin Boolean  @default(true) @map("from_admin")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("motivation_messages")
}

model Category {
  id        String     @id @default(cuid())
  name      String     @unique
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")
  trainings Training[]

  @@map("categories")
}

model Training {
  id          String    @id @default(cuid())
  title       String
  description String?
  imageUrl    String?   @map("image_url")
  categoryId  String?   @map("category_id")
  category    Category? @relation(fields: [categoryId], references: [id])
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  modules     Module[]

  @@map("trainings")
}

model Module {
  id          String   @id @default(cuid())
  title       String
  description String?
  imageUrl    String?  @map("image_url")
  videoUrl    String?  @map("video_url")
  order       Int
  trainingId  String   @map("training_id")
  training    Training @relation(fields: [trainingId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("modules")
}

// チャプター進捗
model ModuleProgress {
  id          String   @id @default(cuid())
  userId      Int      @map("user_id")
  moduleId    String   @map("module_id")
  completed   Boolean  @default(false)
  completedAt DateTime? @map("completed_at")
  deadline    DateTime? @map("deadline")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@unique([userId, moduleId])
  @@map("module_progress")
}

// 面談
model Interview {
  id          String   @id @default(cuid())
  userId      Int      @map("user_id")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  interviewDate DateTime @map("interview_date")
  content     String?  // テキスト内容
  pdfUrl      String?  @map("pdf_url") // PDFファイルURL
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("interviews")
}

// 面談スケジュール枠（管理者が○×で設定）
model MeetingSlot {
  id          String   @id @default(cuid())
  slotDate    DateTime @map("slot_date") // 日付（00:00:00）
  timeSlot    String   @map("time_slot") // "10:00", "11:00" 等
  isAvailable Boolean  @default(true) @map("is_available") // ○=true, ×=false
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  bookings    MeetingBooking[]

  @@unique([slotDate, timeSlot])
  @@map("meeting_slots")
}

// 面談予約（LPからの無料相談申込）
model MeetingBooking {
  id                      String              @id @default(cuid())
  slotId                  String              @map("slot_id")
  slot                    MeetingSlot         @relation(fields: [slotId], references: [id], onDelete: Cascade)
  diagnosisSubmissionId    String?             @map("diagnosis_submission_id")
  diagnosisSubmission     DiagnosisSubmission? @relation(fields: [diagnosisSubmissionId], references: [id], onDelete: SetNull)
  name                    String
  email                   String
  phone                   String?
  message                 String?
  status                  String              @default("pending") // pending, confirmed, cancelled
  adminReadAt             DateTime?           @map("admin_read_at") // 管理者が確認した日時（null=未読）
  createdAt               DateTime            @default(now()) @map("created_at")
  updatedAt               DateTime            @updatedAt @map("updated_at")

  @@map("meeting_bookings")
}
